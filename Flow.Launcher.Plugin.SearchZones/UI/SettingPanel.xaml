<UserControl x:Class="Flow.Launcher.Plugin.SearchZones.UI.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="620">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Width" Value="110"/>
        </Style>
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MinWidth" Value="70"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="DeleteRowButton" TargetType="Button">
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#CC3333"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <StackPanel Margin="16,12" PreviewMouseWheel="Content_PreviewMouseWheel">

            <!-- Everything Search -->
            <TextBlock Text="Everything Search" Style="{StaticResource SectionHeader}"/>
            <Separator Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Everything Path:" Style="{StaticResource Label}" Width="120"/>
                <TextBox x:Name="EverythingPathBox" Grid.Column="1"
                         Padding="4,3" VerticalAlignment="Center"
                         TextChanged="EverythingPathBox_TextChanged"
                         ToolTip="Leer lassen für automatische Erkennung"/>
                <Button Grid.Column="2" Content="..." Width="32" Margin="4,0,0,0"
                        Click="BrowseEverythingButton_Click" ToolTip="Everything64.dll auswählen"
                        Style="{StaticResource SmallButton}"/>
            </Grid>
            <TextBlock x:Name="EverythingStatusText" Margin="124,2,0,12"
                       FontSize="11" TextWrapping="Wrap"/>

            <!-- Templates header + add button -->
            <Grid Margin="0,8,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search Spaces" Style="{StaticResource SectionHeader}" Margin="0"/>
                <Button Grid.Column="1" Content="+ Hinzufügen" Click="AddTemplateButton_Click" VerticalAlignment="Center"/>
            </Grid>
            <Separator Margin="0,0,0,10"/>

            <!-- Template expander list -->
            <ItemsControl x:Name="TemplatesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Each template is an Expander -->
                        <Expander Margin="0,0,0,6" IsExpanded="False"
                                  Tag="{Binding Id}">
                            <Expander.Header>
                                <Grid MinWidth="400">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Shortcut}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding EntriesSummary}"
                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                            </Expander.Header>

                            <!-- Expander content: inline edit + grouped entry lists -->
                            <Border BorderThickness="0,0,0,0" Padding="8,6,4,8" Margin="16,0,0,0">
                                <StackPanel>

                                    <!-- Basic fields -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Shortcut:"
                                                   Style="{StaticResource Label}" Margin="0,0,8,5"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Padding="4,3" Margin="0,0,0,5"
                                                 Tag="{Binding Id}"
                                                 Text="{Binding Shortcut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="TemplateField_LostFocus"
                                                 ToolTip="Kürzel für Flow Launcher (z.B. ds, dl)"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:"
                                                   Style="{StaticResource Label}" Margin="0,0,8,5"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Padding="4,3" Margin="0,0,0,5"
                                                 Tag="{Binding Id}"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="TemplateField_LostFocus"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Beschreibung:"
                                                   Style="{StaticResource Label}" Margin="0,0,8,5"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Padding="4,3" Margin="0,0,0,5"
                                                 Tag="{Binding Id}"
                                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 LostFocus="TemplateField_LostFocus"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Unterordner:"
                                                   Style="{StaticResource Label}" Margin="0,0,8,0"/>
                                        <CheckBox Grid.Row="3" Grid.Column="1"
                                                  Content="Unterordner durchsuchen"
                                                  IsChecked="{Binding SearchSubdirectories, Mode=TwoWay}"
                                                  Tag="{Binding Id}"
                                                  Checked="SubdirsCheckBox_Changed"
                                                  Unchecked="SubdirsCheckBox_Changed"
                                                  VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- ── Folders ───────────────────────────────────────────── -->
                                    <TextBlock Text="── Folders" Style="{StaticResource GroupHeader}"/>
                                    <ItemsControl x:Name="FolderItemsControl"
                                                  ItemsSource="{Binding FolderEntries}"
                                                  Tag="{Binding Id}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Value}"
                                                               VerticalAlignment="Center" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                               VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                               Margin="6,0" MinWidth="60"/>
                                                    <Button Grid.Column="2" Content="✕"
                                                            Style="{StaticResource DeleteRowButton}"
                                                            Tag="{Binding Id}"
                                                            Click="RemoveEntry_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Add folder row -->
                                    <Grid Margin="0,4,0,0" Tag="{Binding Id}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="NewFolderValueBox"
                                                 Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                 Tag="{Binding Id}"
                                                 ToolTip="Pfad eingeben oder Browse klicken"/>
                                        <Button Grid.Column="1" Content="📁 Browse"
                                                Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                Tag="{Binding Id}"
                                                Click="BrowseFolderButton_Click"/>
                                        <TextBox Grid.Column="2" x:Name="NewFolderLabelBox"
                                                 Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                 Width="100" Margin="4,0,0,0"
                                                 Tag="{Binding Id}"
                                                 ToolTip="Label (optional)"/>
                                        <Button Grid.Column="3" Content="+ Add"
                                                Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                Tag="{Binding Id}"
                                                Click="AddFolderEntry_Click"/>
                                    </Grid>

                                    <!-- ── Plugin Commands ───────────────────────────────────── -->
                                    <TextBlock Text="── Plugin Commands" Style="{StaticResource GroupHeader}"/>
                                    <ItemsControl ItemsSource="{Binding PluginCommandEntries}"
                                                  Tag="{Binding Id}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayLabel}"
                                                               VerticalAlignment="Center" FontSize="12"
                                                               FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                               VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Grid.Column="2" Content="✕"
                                                            Style="{StaticResource DeleteRowButton}"
                                                            Tag="{Binding Id}"
                                                            Click="RemoveEntry_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Add plugin command row -->
                                    <Grid Margin="0,4,0,0" Tag="{Binding Id}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" x:Name="NewPluginValueBox"
                                                  IsEditable="True" StaysOpenOnEdit="True"
                                                  IsTextSearchEnabled="False"
                                                  HorizontalAlignment="Stretch"
                                                  MaxDropDownHeight="300"
                                                  Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                  Tag="{Binding Id}"
                                                  ToolTip="Tippen zum Filtern – FL-Keyword oder Programm wählen"
                                                  ItemsSource="{DynamicResource PluginCommandItems}"
                                                  GotFocus="PluginComboBox_GotFocus">
                                            <ComboBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel VirtualizationMode="Recycling"/>
                                                </ItemsPanelTemplate>
                                            </ComboBox.ItemsPanel>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}"
                                                                   FontWeight="SemiBold" MinWidth="100"/>
                                                        <TextBlock Text=" — "
                                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                                        <TextBlock Text="{Binding Category, Mode=OneWay}"
                                                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                                   FontSize="11"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="1" Content="📁"
                                                Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                Tag="{Binding Id}"
                                                Click="BrowseExeButton_Click"
                                                ToolTip=".exe Datei auswählen"/>
                                        <TextBox Grid.Column="2" x:Name="NewPluginLabelBox"
                                                 Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                 Width="100" Margin="4,0,0,0"
                                                 Tag="{Binding Id}"
                                                 ToolTip="Label (optional)"/>
                                        <Button Grid.Column="3" Content="+ Add"
                                                Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                Tag="{Binding Id}"
                                                Click="AddPluginCommandEntry_Click"/>
                                    </Grid>

                                    <!-- ── Quick Commands ────────────────────────────────────── -->
                                    <TextBlock Text="── Quick Commands" Style="{StaticResource GroupHeader}"/>
                                    <ItemsControl ItemsSource="{Binding QuickCommandEntries}"
                                                  Tag="{Binding Id}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Value}"
                                                               VerticalAlignment="Center" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                               VerticalAlignment="Center" FontSize="11"
                                                               Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                                               Margin="6,0" MinWidth="60"/>
                                                    <Button Grid.Column="2" Content="✕"
                                                            Style="{StaticResource DeleteRowButton}"
                                                            Tag="{Binding Id}"
                                                            Click="RemoveEntry_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Add quick command row -->
                                    <Grid Margin="0,4,0,0" Tag="{Binding Id}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Name="NewQuickValueBox"
                                                 Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                 Tag="{Binding Id}"
                                                 ToolTip="URL (https://…) oder Shell-Befehl (z.B. ipconfig)"/>
                                        <TextBox Grid.Column="1" x:Name="NewQuickLabelBox"
                                                 Padding="4,2" FontSize="12" VerticalAlignment="Center"
                                                 Width="100" Margin="4,0,0,0"
                                                 Tag="{Binding Id}"
                                                 ToolTip="Label (optional)"/>
                                        <Button Grid.Column="2" Content="+ Add"
                                                Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                                Tag="{Binding Id}"
                                                Click="AddQuickCommandEntry_Click"/>
                                    </Grid>

                                    <!-- Delete template -->
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                        <Button Content="✕ Template löschen"
                                                Tag="{Binding Id}"
                                                Click="DeleteTemplate_Click"
                                                Foreground="#CC3333"/>
                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Import / Export -->
            <Separator Margin="0,16,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📥 Import JSON" Click="ImportJson_Click" Margin="0,0,8,0"/>
                <Button Content="📤 Export JSON" Click="ExportJson_Click"/>
            </StackPanel>

    </StackPanel>
</UserControl>
